    <!-- Script điều khiển -->
    <script>
        // Mặc định thiết lập iOS trước
        let currentPlatform = 'ios'; 
        let keysList = ['ZERES-OB53-VIP', 'FREE-KEYS-999', 'HEADSHOT-FAST'];
        
        if (!localStorage.getItem('ff_valid_keys')) {
            localStorage.setItem('ff_valid_keys', JSON.stringify(keysList));
        } else {
            keysList = JSON.parse(localStorage.getItem('ff_valid_keys'));
        }

        function showToast(msg) {
            const toast = document.getElementById('customToast');
            document.getElementById('toastMessage').textContent = msg;
            toast.classList.remove('translate-y-[-100px]', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');
            
            setTimeout(() => {
                toast.classList.remove('translate-y-0', 'opacity-100');
                toast.classList.add('translate-y-[-100px]', 'opacity-0');
            }, 3000);
        }

        function renderKeys() {
            const container = document.getElementById('keyListContainer');
            container.innerHTML = '';
            keysList.forEach(key => {
                const item = document.createElement('div');
                item.className = 'flex justify-between items-center bg-zinc-900 p-1.5 rounded border border-zinc-800 mb-1';
                item.innerHTML = `
                    <span>${key}</span>
                    <button onclick="copyAdminKey('${key}')" class="text-[10px] text-zinc-400 hover:text-white underline">Copy</button>
                `;
                container.appendChild(item);
            });
        }
        renderKeys();

        // Thay đổi hệ điều hành (ƯU TIÊN IOS TRƯỚC)
        function selectPlatform(platform) {
            currentPlatform = platform;
            const btnAdr = document.getElementById('tabAdr');
            const btnIos = document.getElementById('tabIos');
            if (platform === 'ios') {
                btnIos.className = "py-3.5 rounded-lg border-2 border-red-500 bg-red-950/40 text-red-400 font-bold tracking-wide text-xs flex items-center justify-center gap-2 transition-all";
                btnAdr.className = "py-3.5 rounded-lg border-2 border-zinc-800 bg-zinc-900/60 text-zinc-400 font-bold tracking-wide text-xs flex items-center justify-center gap-2 transition-all";
                document.getElementById('deviceNameInput').placeholder = "Ví dụ: IPHONE 15 PRO, IPAD AIR 5...";
            } else {
                btnAdr.className = "py-3.5 rounded-lg border-2 border-red-500 bg-red-950/40 text-red-400 font-bold tracking-wide text-xs flex items-center justify-center gap-2 transition-all";
                btnIos.className = "py-3.5 rounded-lg border-2 border-zinc-800 bg-zinc-900/60 text-zinc-400 font-bold tracking-wide text-xs flex items-center justify-center gap-2 transition-all";
                document.getElementById('deviceNameInput').placeholder = "Ví dụ: SAMSUNG S24, XIAOMI REDMI NOTE 13...";
            }
        }

        // Đăng nhập bảo mật
        function validateKey() {
            const inputVal = document.getElementById('activationKeyInput').value.trim();
            const errorMsg = document.getElementById('keyErrorMsg');
            const successMsg = document.getElementById('keySuccessMsg');
            
            errorMsg.classList.add('hidden');
            successMsg.classList.add('hidden');

            if (inputVal.toLowerCase() === 'nickdz') {
                document.getElementById('adminPanel').classList.remove('hidden');
                successMsg.textContent = "✔️ Bạn đã mở khóa giao diện QUẢN TRỊ ADMIN (NICKDZ)";
                successMsg.classList.remove('hidden');
                unlockMainApp();
                return;
            }

            const normalizedKeys = keysList.map(k => k.toUpperCase().trim());
            if (normalizedKeys.includes(inputVal.toUpperCase())) {
                successMsg.textContent = "✔️ Mã khóa hợp lệ! Đang hiệu chỉnh hệ thống kéo tâm...";
                successMsg.classList.remove('hidden');
                setTimeout(() => {
                    unlockMainApp();
                }, 1000);
            } else {
                errorMsg.classList.remove('hidden');
            }
        }

        function logoutAdmin() {
            document.getElementById('adminPanel').classList.add('hidden');
            document.getElementById('mainDiagnosticApp').classList.add('hidden');
            document.getElementById('mainDiagnosticApp').style.opacity = '0';
            document.getElementById('keyGateSection').classList.remove('hidden');
            document.getElementById('activationKeyInput').value = '';
            document.getElementById('keySuccessMsg').classList.add('hidden');
        }

        function generateNewKey() {
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
            let newKey = 'ZERES-OB53-';
            for (let i = 0; i < 6; i++) {
                newKey += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            keysList.push(newKey);
            localStorage.setItem('ff_valid_keys', JSON.stringify(keysList));
            renderKeys();
            showToast("Tạo key thành công: " + newKey);
        }

        function copyAdminKey(key) {
            const el = document.createElement('textarea');
            el.value = key;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);
            showToast("Đã sao chép key: " + key);
        }

        function unlockMainApp() {
            document.getElementById('keyGateSection').classList.add('hidden');
            const mainApp = document.getElementById('mainDiagnosticApp');
            mainApp.classList.remove('hidden');
            setTimeout(() => {
                mainApp.style.opacity = '1';
                mainApp.classList.remove('translate-y-4');
            }, 100);
        }

        function startDiagnosis() {
            const deviceName = document.getElementById('deviceNameInput').value.trim();
            if (!deviceName) {
                showToast("Vui lòng nhập tên dòng máy của bạn!");
                return;
            }

            const loader = document.getElementById('diagnosticLoader');
            const resultBox = document.getElementById('resultBox');
            const progress = document.getElementById('loaderProgressBar');
            const statusText = document.getElementById('loaderStatusText');

            resultBox.classList.add('hidden');
            loader.classList.remove('hidden');
            progress.style.width = '0%';

            const steps = [
                { p: 25, t: "🔍 Tính toán trở kháng lớp kính cường lực & ma sát bề mặt..." },
                { p: 60, t: "⚖️ Đang đồng bộ hóa hệ số kéo dọc α_Drag để giảm nặng tâm..." },
                { p: 85, t: "🛡️ Áp dụng bộ lọc khử nhiễu β_Shake triệt tiêu rung tâm vật lý..." },
                { p: 100, t: "✅ Hoàn tất! Đã xuất ma trận thông số hiệu chỉnh." }
            ];

            let stepIdx = 0;
            const interval = setInterval(() => {
                if (stepIdx < steps.length) {
                    progress.style.width = steps[stepIdx].p + '%';
                    statusText.textContent = steps[stepIdx].t;
                    stepIdx++;
                } else {
                    clearInterval(interval);
                    setTimeout(() => {
                        loader.classList.add('hidden');
                        displayResults(deviceName);
                    }, 400);
                }
            }, 400);
        }

        // TÍNH TOÁN ĐỘ NHẠY CHUẨN VỚI HỆ SỐ PHẦN CỨNG THỰC TẾ
        function displayResults(device) {
            document.getElementById('resDeviceName').textContent = device.toUpperCase();
            
            let seed = 0;
            for (let i = 0; i < device.length; i++) {
                seed += device.charCodeAt(i);
            }

            // Thiết lập hệ số kỹ thuật ban đầu
            let alpha = 1.0; // Hệ số kéo dọc (Nhẹ tâm)
            let beta = 1.0;  // Hệ số ổn định (Chống rung tâm)

            // Điều chỉnh hệ số dựa trên các tùy chọn trợ năng
            if (document.getElementById('tweakNheTam').checked) {
                alpha += 0.15; // Tăng hiệu suất kéo dọc để chống nặng tâm
            }
            if (document.getElementById('tweakChongLo').checked) {
                alpha -= 0.05; // Giảm nhẹ gia tốc cực đại để hạn chế vượt quá đầu
            }
            if (document.getElementById('tweakAntiShake').checked) {
                beta += 0.20;  // Tăng cường tính năng lọc nhiễu xung nhịp cảm ứng
            }

            document.getElementById('valAlpha').textContent = alpha.toFixed(2);
            document.getElementById('valBeta').textContent = beta.toFixed(2);

            // TÍNH TOÁN DẢI ĐỘ NHẠY VỚI MAX LÀ 200 (Thống kê kỹ thuật chuẩn không bị ảo)
            let general = 0;
            let redDot = 0;

            if (currentPlatform === 'ios') {
                // Với iOS: Nhạy cao sẵn, dễ bị lố đầu nếu kéo quá tay, dễ bị rung tâm do màn hình 120Hz/240Hz.
                // General tối ưu nằm trong khoảng 180 - 195 dựa trên hệ số kéo
                general = Math.floor((175 + (seed % 15)) * alpha);
                general = Math.min(200, Math.max(160, general));

                // Red Dot lý tưởng để triệt tiêu Rung và Lố đầu phải thấp hơn General để tạo điểm phanh
                redDot = Math.floor((general - 25 - (seed % 10)) / (beta / 1.1));
                redDot = Math.min(185, Math.max(140, redDot));
            } else {
                // Với Android: Thường bị Nặng tâm do tấm nền cảm ứng có độ trì cao hơn.
                // Đẩy General lên sát mức trần 190 - 200 để bứt tốc lực vuốt
                general = Math.floor((185 + (seed % 12)) * alpha);
                general = Math.min(200, Math.max(170, general));

                // Red Dot cho Android được khóa lùi nhẹ để ghim tâm mượt
                redDot = Math.floor((general - 18 - (seed % 8)) / (beta / 1.05));
                redDot = Math.min(190, Math.max(145, redDot));
            }

            // Tính toán ống ngắm có tính hãm lùi khoa học
            let scope2x = Math.floor(redDot * 1.05 * alpha);
            let scope4x = Math.floor(redDot * 0.92 * alpha);
            let sniper = Math.floor(75 + (seed % 15));
            let freeLook = Math.floor(140 + (seed % 20));

            // Đảm bảo không vượt quá mức trần 200
            scope2x = Math.min(200, scope2x);
            scope4x = Math.min(200, scope4x);

            // Nút bắn: Kích thước vàng chống lố đầu là từ 44% - 53%
            let fireButton = 44 + (seed % 10); 

            // Gán dữ liệu lên màn hình kết quả
            document.getElementById('valGeneral').textContent = general;
            document.getElementById('valRedDot').textContent = redDot;
            document.getElementById('valScope2x').textContent = scope2x;
            document.getElementById('valScope4x').textContent = scope4x;
            document.getElementById('valSniper').textContent = sniper;
            document.getElementById('valFreeLook').textContent = freeLook;
            document.getElementById('valFireButton').textContent = fireButton + "%";

            // Chạy hiệu ứng thanh tiến trình dựa trên tỉ lệ Max 200
            setTimeout(() => {
                document.getElementById('barGeneral').style.width = (general / 2) + '%';
                document.getElementById('barRedDot').style.width = (redDot / 2) + '%';
                document.getElementById('barScope2x').style.width = (scope2x / 2) + '%';
                document.getElementById('barScope4x').style.width = (scope4x / 2) + '%';
                document.getElementById('barSniper').style.width = (sniper / 2) + '%';
                document.getElementById('barFreeLook').style.width = (freeLook / 2) + '%';
                document.getElementById('barFireButton').style.width = fireButton + '%';
            }, 100);

            // Khởi tạo bản hướng dẫn can thiệp phần cứng thực tế tương ứng
            generateTweakGuide(seed, device, fireButton);

            document.getElementById('resultBox').classList.remove('hidden');
        }

        // TẠO HƯỚNG DẪN TRỢ NĂNG CAN THIỆP SÂU CÓ TÁC DỤNG THẬT TRÊN THIẾT BỊ 100%
        function generateTweakGuide(seed, device, fireButton) {
            const container = document.getElementById('tweakGuideContent');
            container.innerHTML = '';

            let guideHTML = '';

            if (currentPlatform === 'ios') {
                // Tối ưu can thiệp thực tế cho iPhone để trị NẶNG TÂM & RUNG TÂM
                let keyDelay = (seed % 2 === 0) ? "0.10 giây (Bộ lọc chống rung cao)" : "0.15 giây (Cân bằng gia tốc)";
                let scaleZoom = "Thu phóng màn hình (Display Zoom) -> Đặt ở mục 'Chữ lớn hơn' (Larger Text). Đây là mẹo phần cứng để giảm độ phân giải hiển thị, giúp tăng mật độ nhạy cảm ứng ảo lên 120% thực tế, vuốt cực nhẹ!";
                
                guideHTML += `
                    <div class="p-3 bg-red-950/25 rounded border border-red-900/30">
                        <strong class="text-red-400">🔥 TRỊ NẶNG TÂM (TĂNG NHẠY VUỐT DỌC):</strong><br>
                        - Vào Cài đặt máy -> Màn hình & Cỡ chữ -> <span class="text-yellow-400 font-bold">${scaleZoom}</span><br>
                        - Vào Trợ năng -> Điều khiển công tắc -> Con trỏ trượt -> Chọn chế độ <span class="text-yellow-400 font-bold">Chính xác (Refined)</span> và đặt tốc độ ở mức <span class="text-yellow-400 font-bold">120</span>. Hành động này sẽ ép xung nhịp quét con trỏ của iOS lên tối đa.
                    </div>
                    <div class="p-3 bg-red-950/25 rounded border border-red-900/30">
                        <strong class="text-red-400">🩺 TRỊ RUNG TÂM & CHỐNG LỐ ĐẦU (ANTI-SHAKE):</strong><br>
                        - Vào Trợ năng -> AssistiveTouch -> Tốc độ theo dõi điều chỉnh giảm về đúng mức <span class="text-yellow-400 font-bold">38%</span>. Cài đặt này giúp khóa hồng tâm Red Dot bám sát đầu khi bạn vuốt nhanh.<br>
                        - Vào Trợ năng -> Cảm ứng -> <b>Thích nghi cảm ứng</b> (Touch Accommodations) -> Bật và đặt <span class="text-yellow-400 font-bold">Thời gian giữ</span> ở mức <span class="text-yellow-400 font-bold">${keyDelay}</span>. Thiết lập này đóng vai trò như một bộ lọc phần cứng hấp thụ toàn bộ lực rung từ ngón tay khi vuốt nút bắn.
                    </div>
                `;
            } else {
                // Tối ưu can thiệp thực tế cho Android
                let optimizedDpi = 460 + (seed % 60);
                guideHTML += `
                    <div class="p-3 bg-red-950/25 rounded border border-red-900/30">
                        <strong class="text-red-400">🔥 TRỊ NẶNG TÂM TRÊN ANDROID:</strong><br>
                        - Vào Cài đặt nhà phát triển -> <span class="text-yellow-400 font-bold">Độ rộng nhỏ nhất (DPI)</span> chỉnh lên đúng <span class="text-yellow-400 font-bold">${optimizedDpi} DPI</span>. Điều này sẽ giải phóng độ nhạy cảm ứng gốc của thiết bị.<br>
                        - Bật tính năng Tăng tốc trò chơi (Game Turbo / Game Booster) mặc định trên máy để giảm độ trễ phản hồi màn hình cảm ứng xuống mức thấp nhất.
                    </div>
                    <div class="p-3 bg-red-950/25 rounded border border-red-900/30">
                        <strong class="text-red-400">🩺 TRỊ RUNG TÂM TRÊN ANDROID:</strong><br>
                        - Chỉnh kích thước nút bắn trong cài đặt game ở mức chính xác <span class="text-yellow-400 font-bold">${fireButton}%</span>. Đặt nút bắn thấp xuống sát mép dưới để tăng tối đa hành trình vuốt dọc ổn định.<br>
                        - Vào Cài đặt -> Hỗ trợ tiếp cận -> Độ trễ chạm giữ đặt ở mức <span class="text-yellow-400 font-bold">Ngắn (0.5s)</span> để ổn định đường truyền tín hiệu cảm ứng.
                    </div>
                `;
            }

            container.innerHTML = guideHTML;
        }

        function copyToClipboard() {
            const gen = document.getElementById('valGeneral').textContent;
            const red = document.getElementById('valRedDot').textContent;
            const s2x = document.getElementById('valScope2x').textContent;
            const s4x = document.getElementById('valScope4x').textContent;
            const snp = document.getElementById('valSniper').textContent;
            const free = document.getElementById('valFreeLook').textContent;
            const fire = document.getElementById('valFireButton').textContent;
            const dev = document.getElementById('resDeviceName').textContent;

            const textToCopy = `Độ Nhạy VIP OB53 [${dev}]: Nhìn xung quanh: ${gen} | Red Dot: ${red} | 2x: ${s2x} | 4x: ${s4x} | Sniper: ${snp} | Free Look: ${free} | Nút bắn: ${fire}`;

            const el = document.createElement('textarea');
            el.value = textToCopy;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);

            showToast("Đã sao chép cấu hình độ nhạy hiệu chỉnh!");
        }

        // ================= HIỆU ỨNG TUYẾT RƠI & ĐÈN ĐỎ LUNG LINH =================
        const canvas = document.getElementById('snowCanvas');
        const ctx = canvas.getContext('2d');

        let particles = [];
        const maxParticles = 75;

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        class Particle {
            constructor() {
                this.reset();
            }

            reset() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * -canvas.height;
                this.size = Math.random() * 2.5 + 0.8;
                this.speedY = Math.random() * 1.0 + 0.3;
                this.speedX = (Math.random() - 0.5) * 0.4;
                this.opacity = Math.random() * 0.6 + 0.2;
                this.isRedGlow = Math.random() < 0.4; // Tăng tỉ lệ hạt phát xạ đỏ tạo không khí rực cháy
            }

            update() {
                this.y += this.speedY;
                this.x += this.speedX;

                if (this.y > canvas.height) {
                    this.reset();
                }
            }

            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                if (this.isRedGlow) {
                    ctx.fillStyle = `rgba(239, 68, 68, ${this.opacity})`;
                    ctx.shadowColor = '#ef4444';
                    ctx.shadowBlur = 6;
                } else {
                    ctx.fillStyle = `rgba(255, 255, 255, ${this.opacity})`;
                    ctx.shadowBlur = 0;
                }
                ctx.fill();
            }
        }

        for (let i = 0; i < maxParticles; i++) {
            particles.push(new Particle());
        }

        function drawGlows() {
            // Nền đèn đỏ chuyển động mượt ở các góc
            const gradient = ctx.createRadialGradient(
                canvas.width / 2, canvas.height, 10,
                canvas.width / 2, canvas.height, canvas.height * 0.9
            );
            gradient.addColorStop(0, 'rgba(100, 5, 5, 0.35)');
            gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
            
            ctx.fillStyle = gradient;
            ctx.fillRect(0, 0, canvas.width, canvas.height);
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            drawGlows();
            
            particles.forEach(p => {
                p.update();
                p.draw();
            });

            requestAnimationFrame(animate);
        }

        window.onload = function() {
            animate();
        }
    </script>
</body>
</html>

