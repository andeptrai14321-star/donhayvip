        /* Khung viền chạy dải cầu vồng chuyển động tương tự ảnh mẫu */
        .glowing-border {
            position: relative;
            background: rgba(10, 3, 3, 0.98);
            border-radius: 16px;
            z-index: 10;
        }

        .glowing-border::before {
            content: '';
            position: absolute;
            top: -2.5px;
            left: -2.5px;
            right: -2.5px;
            bottom: -2.5px;
            background: linear-gradient(45deg, #ff0000, #ff5e00, #e100ff, #00f0ff, #00ff66, #ff0000);
            background-size: 300%;
            z-index: -1;
            border-radius: 18px;
            animation: rainbowShift 8s linear infinite;
            filter: blur(2px);
            opacity: 0.95;
        }

        @keyframes rainbowShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Đổ bóng phát xạ đỏ */
        .red-shadow-glow {
            box-shadow: 0 0 35px rgba(239, 68, 68, 0.3);
            border: 1px solid rgba(239, 68, 68, 0.35);
        }

        /* Hiệu ứng quét dòng quét radar */
        .scan-line {
            position: relative;
            overflow: hidden;
        }
        .scan-line::after {
            content: '';
            position: absolute;
            top: -100%;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to bottom, transparent, rgba(239, 68, 68, 0.4), transparent);
            animation: scan 3s linear infinite;
        }
        @keyframes scan {
            0% { top: -100%; }
            100% { top: 100%; }
        }
    </style>
</head>
